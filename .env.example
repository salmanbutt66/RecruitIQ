# Database
DATABASE_URL=postgresql+asyncpg://recruitiq:recruitiq@postgres:5432/recruitiq
POSTGRES_USER=recruitiq
POSTGRES_PASSWORD=recruitiq
POSTGRES_DB=recruitiq

# Redis
REDIS_URL=redis://redis:6379

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recruitiq-resumes
MINIO_SECURE=false

# LLM Gateway
LITELLM_BASE_URL=http://litellm:4000
GROQ_API_KEY=
OPENAI_API_KEY=

# Auth
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=RecruitIQ <onboarding@resend.dev>

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Observability
LOGFIRE_TOKEN=
LOGFIRE_PROJECT=recruitiq

# App URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:8000

# App
APP_ENV=development
DEBUG=true

# Platform admin (for admin portal at http://localhost:3001)
PLATFORM_ADMIN_EMAIL=admin@recruitiq.local
PLATFORM_ADMIN_PASSWORD=changeme123
PLATFORM_ADMIN_NAME=Platform Admin
